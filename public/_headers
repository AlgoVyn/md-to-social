# Cloudflare Pages Security Headers
# https://developers.cloudflare.com/pages/configuration/headers/

# Global headers for all routes
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  X-DNS-Prefetch-Control: on
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Cache static assets for 1 year (immutable)
/marksocial/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache images for 1 week
/marksocial/logo/*
  Cache-Control: public, max-age=604800, immutable

# Cache manifest and config files for 1 day
/marksocial/manifest.json
  Cache-Control: public, max-age=86400

/marksocial/browserconfig.xml
  Cache-Control: public, max-age=86400

# Security headers for sensitive files
/marksocial/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  X-Content-Type-Options: nosniff
